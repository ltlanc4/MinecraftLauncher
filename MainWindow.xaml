<Window x:Class="MinecraftLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OtonashiRei MCServer"
        Height="720"
        Width="1280"
        Icon="pack://application:,,,/Assets/icon.jpg"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F36895"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FA8EB1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BFA6C4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#F36895"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Control" x:Key="ModernInput">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#25142B"/>
            <Setter Property="BorderBrush" Value="#452751"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E2D4E6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckBorder" Grid.Column="0" Width="18" Height="18" Background="#25142B" BorderBrush="#452751" BorderThickness="1" CornerRadius="3" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Path x:Name="CheckMark" Data="M 0,3 L 3,6 L 8,0" Stroke="White" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#F36895"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#F36895"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#F36895"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#150B1A">
        <Image Source="pack://application:,,,/Assets/bg.png" Stretch="UniformToFill"/>
        <Rectangle Fill="#33000000"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1" Background="#F2140A18" Padding="40" BorderBrush="#F36895" BorderThickness="4,0,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <!-- NÚT NGÔN NGỮ Ở MÀN HÌNH ĐĂNG NHẬP -->
                        <Button x:Name="btnLanguage" Content="EN-US" Width="50" Height="30" Cursor="Hand" Click="btnLanguage_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F36895"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="—" Width="40" Height="30" Cursor="Hand" Click="MinimizeButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F36895"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="✕" Width="40" Height="30" Cursor="Hand" Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F36895"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <StackPanel x:Name="LoginPanel" VerticalAlignment="Center" Visibility="Visible">
                        <WrapPanel Margin="0,0,0,40">
                            <TextBlock Text="OTONASHIREI " FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="MCSERVER" FontSize="28" FontWeight="Bold" Foreground="#F36895"/>
                        </WrapPanel>

                        <TextBlock x:Name="lblLoginUsernameStr" Text="TÀI KHOẢN" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtLoginUsername" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,20"/>

                        <TextBlock x:Name="lblLoginPasswordStr" Text="MẬT KHẨU" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="txtLoginPassword" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,20"/>

                        <CheckBox x:Name="chkRememberMe" Content="Ghi nhớ đăng nhập" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,30"/>

                        <Button x:Name="btnLogin" Content="ĐĂNG NHẬP" Style="{StaticResource PrimaryButton}" Click="LoginButton_Click" Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Cursor="Hand" MouseDown="SwitchToRegister_MouseDown">
                                <TextBlock x:Name="lblRegisterPrompt" Text="Chưa có tài khoản?" Foreground="#BFA6C4"/>
                                <!-- Đã thêm Margin="5,0,0,0" để cách lề trái 5 pixel -->
                                <TextBlock x:Name="btnRegisterText" Text="Đăng Ký" Foreground="#F36895" FontWeight="Bold" Margin="5,0,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" x:Name="btnForgotPassword" Text="Quên Mật Khẩu?" Foreground="#BFA6C4" Cursor="Hand" MouseDown="SwitchToForgotPass_MouseDown"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="RegisterPanel" VerticalAlignment="Center" Visibility="Collapsed">
                        <WrapPanel Margin="0,0,0,30">
                            <TextBlock x:Name="lblRegTitle1" Text="ĐĂNG KÝ " FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="lblRegTitle2" Text="TÀI KHOẢN" FontSize="28" FontWeight="Bold" Foreground="#F36895"/>
                        </WrapPanel>

                        <TextBlock x:Name="lblRegUsernameStr" Text="TÊN ĐĂNG NHẬP (TRONG GAME)" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtRegUsername" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,15"/>

                        <TextBlock x:Name="lblRegEmailStr" Text="EMAIL KHÔI PHỤC" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtRegEmail" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,15"/>

                        <TextBlock x:Name="lblRegPasswordStr" Text="MẬT KHẨU" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="txtRegPassword" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,15"/>

                        <TextBlock x:Name="lblRegConfirmStr" Text="XÁC NHẬN MẬT KHẨU" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="txtRegConfirm" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,30"/>

                        <Button x:Name="btnRegister" Content="TẠO TÀI KHOẢN" Style="{StaticResource PrimaryButton}" Click="RegisterButton_Click" Margin="0,0,0,10"/>
                        <Button x:Name="btnBackToLogin1" Content="Quay lại Đăng nhập" Style="{StaticResource SecondaryButton}" Click="BackToLogin_Click"/>
                    </StackPanel>

                    <Grid x:Name="ForgotPasswordPanel" VerticalAlignment="Center" Visibility="Collapsed">
                        <StackPanel x:Name="pnlRecoveryStep1" Visibility="Visible">
                            <WrapPanel Margin="0,0,0,20">
                                <TextBlock x:Name="lblForgotTitle1" Text="KHÔI PHỤC " FontSize="28" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="lblForgotTitle2" Text="MẬT KHẨU" FontSize="28" FontWeight="Bold" Foreground="#F36895"/>
                            </WrapPanel>

                            <TextBlock x:Name="lblForgotDesc" Text="Vui lòng nhập Tên tài khoản và Email đã đăng ký để hệ thống gửi mã khôi phục mật khẩu." Foreground="#BFA6C4" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="22"/>

                            <TextBlock x:Name="lblForgotUserStr" Text="TÊN TÀI KHOẢN" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtRecoveryUsername" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,15"/>

                            <TextBlock x:Name="lblForgotEmailStr" Text="EMAIL ĐĂNG KÝ" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtRecoveryEmail" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,30"/>

                            <Button x:Name="btnSendCode" Content="GỬI MÃ KHÔI PHỤC" Style="{StaticResource PrimaryButton}" Click="SendRecoveryCode_Click" Margin="0,0,0,10"/>
                            <Button x:Name="btnBackToLogin2" Content="Quay lại Đăng nhập" Style="{StaticResource SecondaryButton}" Click="BackToLogin_Click"/>
                        </StackPanel>

                        <StackPanel x:Name="pnlRecoveryStep2" Visibility="Collapsed">
                            <WrapPanel Margin="0,0,0,20">
                                <TextBlock x:Name="lblResetTitle1" Text="ĐẶT LẠI " FontSize="28" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="lblResetTitle2" Text="MẬT KHẨU" FontSize="28" FontWeight="Bold" Foreground="#F36895"/>
                            </WrapPanel>

                            <TextBlock x:Name="lblResetDesc" Text="Mã xác nhận gồm 6 chữ số đã được gửi đến Email của bạn. Vui lòng kiểm tra hộp thư." Foreground="#BFA6C4" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="22"/>

                            <TextBlock x:Name="lblResetOtpStr" Text="MÃ XÁC NHẬN (OTP)" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtRecoveryCode" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,15"/>

                            <TextBlock x:Name="lblResetNewPassStr" Text="MẬT KHẨU MỚI" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="txtRecoveryNewPass" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,15"/>

                            <TextBlock x:Name="lblResetConfirmStr" Text="XÁC NHẬN MẬT KHẨU MỚI" Foreground="#BFA6C4" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="txtRecoveryConfirmPass" Style="{StaticResource ModernInput}" Height="45" Margin="0,0,0,30"/>

                            <Button x:Name="btnConfirmReset" Content="ĐỔI MẬT KHẨU" Style="{StaticResource PrimaryButton}" Click="ConfirmResetPassword_Click" Margin="0,0,0,10"/>
                            <Button x:Name="btnCancelReset" Content="Hủy và Quay lại" Style="{StaticResource SecondaryButton}" Click="BackToLogin_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Background="#F2140A18" Margin="-40" Panel.ZIndex="20">
                        <Grid.Resources>
                            <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="SpinnerTransform" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1"/>
                            </Storyboard>
                        </Grid.Resources>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="50" Height="50">
                                <Ellipse Stroke="#26F36895" StrokeThickness="4"/>
                                <Ellipse Stroke="#F36895" StrokeThickness="4" StrokeDashArray="3 1">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="SpinnerTransform" CenterX="25" CenterY="25"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <TextBlock x:Name="lblLoadingText" Text="Đ A N G   X Á C   T H Ự C . . ." Foreground="#F36895" FontWeight="Bold" FontSize="13" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>