<Window x:Class="MinecraftLauncher.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification" Width="320" SizeToContent="Height" MinHeight="80"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        Opacity="0">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.3"/>
                    
                    <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                        From="0,20,0,-20" To="0" Duration="0:0:0.3">
                        <ThicknessAnimation.EasingFunction>
                            <PowerEase Power="3" EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#E6140A18" BorderBrush="#33F36895" BorderThickness="1" CornerRadius="8" Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#F36895" Opacity="0.3" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="15,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="28" Height="28" Background="#26F36895" CornerRadius="14" VerticalAlignment="Center">
                <Path Data="M 0,4 L 4,9 L 12,0" 
                      Width="13" Height="10" Stretch="Uniform"
                      Stroke="#F36895" StrokeThickness="2.5" 
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                <TextBlock x:Name="txtTitle" Text="THÀNH CÔNG" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,3"/>
                <TextBlock x:Name="txtMessage" Text="Tài khoản của bạn đã được tạo." Foreground="#E2D4E6" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
            </StackPanel>

            <Button Grid.Column="2" Content="✕" Width="20" Height="20" 
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Background="Transparent" Foreground="#BFA6C4" BorderThickness="0" 
                    FontSize="12" Cursor="Hand" Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F36895"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>