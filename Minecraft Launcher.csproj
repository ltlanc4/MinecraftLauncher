<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>MinecraftLauncher</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>./Assets/icon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="./Assets/bg.png" />
    <Resource Include="./Assets/bg_update.png" />
    <Resource Include="./Assets/icon.jpg" />
    <EmbeddedResource Include="default.env" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CmlLib.Core" Version="3.3.10" />
    <PackageReference Include="DotNetEnv" Version="3.2.0" />
  </ItemGroup>
  
  <ItemGroup>
    <Using Remove="System.Windows.Forms" />
  </ItemGroup>
</Project>
