                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#990F0812"
                        BorderBrush="#22F36895"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,0,20,20">
                    <StackPanel>
                        <TextBlock x:Name="lblAccountSettings"
                                   Text="CÀI ĐẶT TÀI KHOẢN"
                                   Foreground="#BFA6C4"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="10,10,0,15"/>
