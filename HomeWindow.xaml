                                       FontSize="22"
                                       FontWeight="Black"
                                       Margin="0,0,0,30"/>

                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="80"
                                        Height="80"
                                        CornerRadius="40"
                                        Background="#33F36895"
                                        BorderBrush="#F36895"
                                        BorderThickness="2">
                                    <Grid>
                                        <Grid.Clip>
                                            <EllipseGeometry RadiusX="38"
                                                             RadiusY="38"
                                                             Center="38,38"/>
                                        </Grid.Clip>
                                        <TextBlock x:Name="txtDefaultAvatar"
                                                   Text="🎮"
                                                   FontSize="40"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Image x:Name="imgProfileAvatar"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="20,0,0,0">
                                    <TextBlock x:Name="txtProfileDisplayUsername"
                                               Text="[Username]"
                                               Foreground="White"
                                               FontSize="28"
                                               FontWeight="Black"/>
                                    <TextBlock x:Name="lblMemberOf"
                                               Text="Thành viên OtonashiRei Server"
                                               Foreground="#4ADE80"
                                               FontSize="14"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#4C000000"
                                    BorderBrush="#33F36895"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="20"
                                    Width="380"
                                    HorizontalAlignment="Left">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="15"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="lblUsernameStr"
                                               Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Tên đăng nhập:"
                                               Foreground="#BFA6C4"
                                               FontSize="14"/>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               x:Name="txtProfileUsernameValue"
                                               Text="[Username]"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>

                                    <TextBlock x:Name="lblStatusStr"
                                               Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Trạng thái:"
                                               Foreground="#BFA6C4"
                                               FontSize="14"/>
                                    <TextBlock x:Name="lblStatusReady"
                                               Grid.Row="2"
                                               Grid.Column="1"
                                               Text="Đã sẵn sàng"
                                               Foreground="#4ADE80"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="pnlProfileSkin"
                                    Visibility="Collapsed"
                                    Width="380"
                                    HorizontalAlignment="Left">
                            <TextBlock x:Name="lblChangeSkinTitle"
                                       Text="THAY ĐỔI SKIN (DIỆN MẠO)"
                                       Foreground="#F36895"
                                       FontSize="22"
                                       FontWeight="Black"
                                       Margin="0,0,0,25"/>
                            <TextBlock x:Name="lblSkinFormat"
                                       Text="Định dạng hỗ trợ: PNG (64x64 hoặc 64x32)"
                                       Foreground="#BFA6C4"
                                       FontSize="13"
                                       Margin="0,0,0,15"/>

                            <Border Width="120"
                                    Height="120"
                                    BorderBrush="#33F36895"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Background="#4C000000"
                                    Margin="0,0,0,20"
                                    HorizontalAlignment="Left">
                                <Grid>
                                    <TextBlock Text="?"
                                               FontSize="40"
                                               Foreground="#33F36895"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Image x:Name="imgSkinPreview"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                </Grid>
                            </Border>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="btnSelectSkin"
                                        Grid.Column="0"
                                        Content="CHỌN FILE..."
                                        Style="{StaticResource ProfileSecondaryActionButton}"
                                        Click="btnSelectSkin_Click"/>
                                <Button x:Name="btnUploadSkin"
                                        Grid.Column="2"
                                        Content="TẢI LÊN"
                                        IsEnabled="False"
                                        Style="{StaticResource ProfileSecondaryActionButton}"
                                        Click="btnUploadSkin_Click"/>
                            </Grid>
                            <TextBlock x:Name="lblSkinNote"
                                       Text="Cần cài đặt mod CustomSkinLoader hoặc SkinRestorer để hiển thị trong game."
                                       Foreground="#4ADE80"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="pnlProfileEmail"
                                    Visibility="Collapsed"
                                    Width="380"
                                    HorizontalAlignment="Left">
                            <TextBlock x:Name="lblLinkEmailTitle"
                                       Text="LIÊN KẾT EMAIL MỚI"
                                       Foreground="#F36895"
                                       FontSize="22"
                                       FontWeight="Black"
                                       Margin="0,0,0,25"/>

                            <StackPanel x:Name="pnlEmailInput"
                                        Visibility="Visible">
                                <TextBlock x:Name="lblNewEmailStr"
                                           Text="Địa chỉ Email mới"
                                           Foreground="#BFA6C4"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="txtNewEmail"
                                         Margin="0,0,0,20"/>
                                <Button x:Name="btnSendEmailOtp"
                                        Content="ĐỔI EMAIL"
                                        Style="{StaticResource ProfileSecondaryActionButton}"
                                        Click="btnSendEmailOtp_Click"
                                        Margin="0,0,0,25"/>
                            </StackPanel>

                            <StackPanel x:Name="pnlOtpVerify"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="lblEmailOtpStr"
                                           Text="Mã xác nhận OTP (6 số)"
                                           Foreground="#BFA6C4"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="txtEmailOtp"
                                         Margin="0,0,0,20"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="btnCancelEmailOtp"
                                            Grid.Column="0"
                                            Content="HỦY BỎ"
                                            Style="{StaticResource ProfileCancelButton}"
                                            Click="btnCancelEmailOtp_Click"/>
                                    <Button x:Name="btnConfirmEmailChange"
                                            Grid.Column="2"
                                            Content="XÁC NHẬN MÃ"
                                            Style="{StaticResource ProfileSecondaryActionButton}"
                                            Click="btnConfirmEmailChange_Click"/>
                                </Grid>
                                <TextBlock x:Name="lblEmailOtpNote"
                                           Text="Đã gửi OTP đến Email gốc của tài khoản. Vui lòng kiểm tra hộp thư."
                                           Foreground="#4ADE80"
                                           FontSize="12"
                                           Margin="0,15,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="pnlProfilePassword"
                                    Visibility="Collapsed"
                                    Width="380"
                                    HorizontalAlignment="Left">
                            <TextBlock x:Name="lblChangePassTitle"
                                       Text="ĐỔI MẬT KHẨU"
                                       Foreground="#F36895"
                                       FontSize="22"
                                       FontWeight="Black"
                                       Margin="0,0,0,25"/>

                            <StackPanel x:Name="pnlPasswordInput"
                                        Visibility="Visible">
                                <TextBlock x:Name="lblOldPassStr"
                                           Text="Mật khẩu hiện tại"
                                           Foreground="#BFA6C4"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>
                                <PasswordBox x:Name="txtOldPassword"
                                             Margin="0,0,0,20"/>

                                <TextBlock x:Name="lblNewPassStr"
                                           Text="Mật khẩu mới"
                                           Foreground="#BFA6C4"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>
                                <PasswordBox x:Name="txtNewPassword"
                                             Margin="0,0,0,20"/>

                                <TextBlock x:Name="lblConfirmPassStr"
                                           Text="Xác nhận mật khẩu mới"
                                           Foreground="#BFA6C4"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>
                                <PasswordBox x:Name="txtConfirmNewPassword"
                                             Margin="0,0,0,25"/>

                                <Button x:Name="btnSendPasswordOtp"
                                        Content="ĐỔI MẬT KHẨU"
                                        Style="{StaticResource ProfileSecondaryActionButton}"
                                        Click="btnSendPasswordOtp_Click"
                                        Margin="0,0,0,25"/>
                            </StackPanel>

                            <StackPanel x:Name="pnlPasswordOtpVerify"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="lblPassOtpStr"
                                           Text="Mã xác nhận OTP (6 số)"
                                           Foreground="#BFA6C4"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="txtPasswordOtp"
                                         Margin="0,0,0,20"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="btnCancelPasswordOtp"
                                            Grid.Column="0"
                                            Content="HỦY BỎ"
                                            Style="{StaticResource ProfileCancelButton}"
                                            Click="btnCancelPasswordOtp_Click"/>
                                    <Button x:Name="btnConfirmPasswordChange"
                                            Grid.Column="2"
                                            Content="XÁC NHẬN ĐỔI"
                                            Style="{StaticResource ProfileSecondaryActionButton}"
                                            Click="btnConfirmPasswordChange_Click"/>
                                </Grid>
                                <TextBlock x:Name="lblPassOtpNote"
                                           Text="Đã gửi OTP đến Email gốc của tài khoản. Vui lòng kiểm tra hộp thư."
                                           Foreground="#4ADE80"
                                           FontSize="12"
                                           Margin="0,15,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- GIAO DIỆN TRANG CÀI ĐẶT MỚI THÊM -->
            <Grid x:Name="ViewSettings"
                  Grid.Row="1"
                  Grid.ColumnSpan="2"
                  Visibility="Collapsed"
                  Margin="30,30,80,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#990F0812"
                        BorderBrush="#22F36895"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,0,20,20">
                    <StackPanel>
                        <TextBlock x:Name="lblSettingsSidebarTitle"
                                   Text="DANH MỤC CÀI ĐẶT"
                                   Foreground="#BFA6C4"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="10,10,0,15"/>
                        <RadioButton x:Name="radSubSetGeneral"
                                     Content="Cài đặt chung"
                                     Style="{StaticResource ProfileSubTabButton}"
                                     IsChecked="True"
                                     Checked="SubSetGeneral_Checked"/>
                        <RadioButton x:Name="radSubSetGraphics"
                                     Content="Đồ họa"
                                     Style="{StaticResource ProfileSubTabButton}"
                                     Checked="SubSetGraphics_Checked"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="#990F0812"
                        BorderBrush="#22F36895"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="40"
                        Margin="0,0,0,20">
                    <Grid>
                        <StackPanel x:Name="pnlSettingsGeneral"
                                    Visibility="Visible">
                            <TextBlock x:Name="lblSettingsGeneralTitle"
                                       Text="CÀI ĐẶT CHUNG"
                                       Foreground="#F36895"
                                       FontSize="22"
                                       FontWeight="Black"
                                       Margin="0,0,0,30"/>

                            <TextBlock x:Name="lblLanguageStr"
                                       Text="Ngôn ngữ giao diện"
                                       Foreground="#BFA6C4"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="btnChangeLanguage"
                                    Content="Chuyển sang Tiếng Anh (English)"
                                    Style="{StaticResource ProfileSecondaryActionButton}"
                                    HorizontalAlignment="Left"
                                    Width="300"
                                    Click="btnLanguage_Click"
                                    Margin="0,0,0,30"/>

                            <TextBlock x:Name="lblLogoutStr"
                                       Text="Quản lý tài khoản"
                                       Foreground="#BFA6C4"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="btnLogoutApp"
                                    Content="ĐĂNG XUẤT THOÁT KHỎI TÀI KHOẢN"
                                    Style="{StaticResource ProfileCancelButton}"
                                    HorizontalAlignment="Left"
                                    Width="300"
                                    Click="LogoutButton_Click"/>
                        </StackPanel>

                        <StackPanel x:Name="pnlSettingsGraphics"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="lblSettingsGraphicsTitle"
                                       Text="CÀI ĐẶT ĐỒ HỌA"
                                       Foreground="#F36895"
                                       FontSize="22"
                                       FontWeight="Black"
                                       Margin="0,0,0,30"/>

                            <Grid Margin="0,0,0,8"
                                  Width="300"
                                  HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="lblRamStr"
                                           Text="Dung lượng RAM (JVM)"
                                           Foreground="#BFA6C4"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtRamValue"
                                           Text="4096 MB"
                                           Foreground="#F36895"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Slider HorizontalAlignment="Left"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,0,0,30"
                                    Maximum="16384"
                                    Minimum="1024"
                                    Style="{StaticResource SakuraSliderStyle}"
                                    TickFrequency="1024"
                                    Value="4096"
                                    ValueChanged="sliderRam_ValueChanged"
                                    Width="300"
                                    x:Name="sliderRam"/>

                            <TextBlock x:Name="lblShaderStr"
                                       Text="Quản lý Shader (Gói đồ họa)"
                                       Foreground="#BFA6C4"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="btnAddShader"
                                    Content="THÊM FILE SHADER (.ZIP)"
                                    Style="{StaticResource ProfileSecondaryActionButton}"
                                    HorizontalAlignment="Left"
                                    Width="300"
                                    Click="btnAddShader_Click"
                                    Margin="0,0,0,30"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Background="#CC0F0812"
                    BorderBrush="#33F36895"
                    BorderThickness="0,1,0,0">
                <Grid Margin="20,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="DownloadProgressContainer"
                          Grid.Column="0"
                          VerticalAlignment="Center"
                          Margin="10,0,40,0"
                          Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock x:Name="txtDownloadStatus"
                                           Text="Đang kiểm tra..."
                                           Foreground="#BFA6C4"
                                           FontSize="13"/>
                                <TextBlock x:Name="txtDownloadDetail"
                                           Text="0 / 0"
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar x:Name="pbDownload"
                                         Style="{StaticResource SakuraProgressBar}"
                                         Height="10"
                                         Maximum="100"
                                         Value="0"/>
                            <TextBlock x:Name="txtDownloadPercentage"
                                       Text="0%"
                                       Foreground="#F36895"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <StackPanel VerticalAlignment="Center"
                                    Margin="0,0,20,0"
                                    HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,8">
                                <TextBlock x:Name="lblSaveAt"
                                           Text="Lưu tại: "
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtInstallPath"
                                           Text="C:\...\Minecraft"
                                           Foreground="#E2D4E6"
                                           FontSize="11"
                                           MaxWidth="150"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                <Button x:Name="btnChangePath"
                                        Content="Thay đổi"
                                        Foreground="#F36895"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Margin="8,0,0,0"
                                        Cursor="Hand"
                                        Click="ChangePath_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <TextBlock x:Name="txtVersionLabel"
                                           Text="Phiên bản chuẩn bị tải: "
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtGameVersion"
                                           Text="Đang tải..."
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <Grid Width="250"
                              Height="80">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnPlay"
                                    Content="KHỞI ĐỘNG"
                                    Grid.Column="0"
                                    Cursor="Hand"
                                    Click="PlayButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background"
                                                Value="#F2140A18"/>
                                        <Setter Property="Foreground"
                                                Value="#F36895"/>
                                        <Setter Property="BorderBrush"
                                                Value="#33F36895"/>
                                        <Setter Property="BorderThickness"
                                                Value="1,1,0,1"/>
                                        <Setter Property="FontWeight"
                                                Value="Bold"/>
                                        <Setter Property="FontSize"
                                                Value="24"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4,0,0,4">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#F36895"
                                                                              BlurRadius="10"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.2"/>
                                                        </Border.Effect>
                                                        <Grid>
                                                            <Path Data="M 0,20 L 20,0 M 10,40 L 40,10"
                                                                  Stroke="#11F36895"
                                                                  StrokeThickness="2"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Bottom"
                                                                  Margin="10,0,0,10"/>
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#F36895"/>
                                                            <Setter Property="Foreground"
                                                                    Value="#FFFFFF"/>
                                                            <Setter Property="BorderBrush"
                                                                    Value="#F36895"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                            <Setter Property="Opacity"
                                                                    Value="0.5"/>
                                                            <Setter Property="Cursor"
                                                                    Value="Wait"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="btnGameMenu"
                                    Content="≡"
                                    Grid.Column="1"
                                    Cursor="Hand"
                                    Click="btnGameMenu_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background"
                                                Value="#1AF36895"/>
                                        <Setter Property="Foreground"
                                                Value="#F36895"/>
                                        <Setter Property="BorderBrush"
                                                Value="#33F36895"/>
                                        <Setter Property="BorderThickness"
                                                Value="1"/>
                                        <Setter Property="FontSize"
                                                Value="24"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="0,4,4,0">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Margin="0,-4,0,0"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter TargetName="border"
                                                                    Property="Background"
                                                                    Value="#F36895"/>
                                                            <Setter Property="Foreground"
                                                                    Value="White"/>
                                                            <Setter TargetName="border"
                                                                    Property="BorderBrush"
                                                                    Value="#F36895"/>
                                                            <Setter TargetName="border"
                                                                    Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#F36895"
                                                                                      BlurRadius="10"
                                                                                      ShadowDepth="0"
                                                                                      Opacity="0.5"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>

                                <Button.ContextMenu>
                                    <ContextMenu x:Name="GameContextMenu"
                                                 Style="{StaticResource SakuraContextMenu}">
                                        <ContextMenu.Resources>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="FontSize"
                                                        Value="13"/>
                                                <Setter Property="Padding"
                                                        Value="10,8"/>
                                                <Setter Property="Cursor"
                                                        Value="Hand"/>
                                            </Style>

                                            <Style x:Key="UninstallMenuItemStyle"
                                                   TargetType="MenuItem"
                                                   BasedOn="{StaticResource SakuraMenuItem}">
                                                <Setter Property="Foreground"
                                                        Value="#FF4D4D"/>
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>

                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="White"/>

                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="White"
                                                                                  BlurRadius="0"
                                                                                  ShadowDepth="0"
                                                                                  Opacity="0"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContextMenu.Resources>
                                        <MenuItem x:Name="menuOpenFolder"
                                                  Header="Mở thư mục Game"
                                                  Style="{StaticResource SakuraMenuItem}"
                                                  Click="menuOpenFolder_Click"/>

                                        <MenuItem x:Name="menuVerify"
                                                  Header="Xác thực tệp (Verify)"
                                                  Style="{StaticResource SakuraMenuItem}"
                                                  Click="menuVerify_Click"/>

                                        <Separator Margin="10,5,10,5">
                                            <Separator.Template>
                                                <ControlTemplate TargetType="Separator">
                                                    <Border Height="1"
                                                            Background="#66F36895"
                                                            HorizontalAlignment="Stretch"/>
                                                </ControlTemplate>
                                            </Separator.Template>
                                        </Separator>

                                        <MenuItem x:Name="menuUninstall"
                                                  Header="Gỡ cài đặt Game"
                                                  Style="{StaticResource UninstallMenuItemStyle}"
                                                  Click="menuUninstall_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>