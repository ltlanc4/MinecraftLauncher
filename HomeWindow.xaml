                                     Content="Thông tin chung"
                                     Style="{StaticResource ProfileSubTabButton}"
                                     IsChecked="True"
                                     Checked="SubTabInfo_Checked"/>
                        <RadioButton x:Name="radSubTabSkin"
                                     Content="Thay đổi Skin"
                                     Style="{StaticResource ProfileSubTabButton}"
                                     Checked="SubTabSkin_Checked"/>
                        <RadioButton x:Name="radSubTabEmail"
                                     Content="Đổi Email bảo mật"
                                     Style="{StaticResource ProfileSubTabButton}"
                                     Checked="SubTabEmail_Checked"/>
                        <RadioButton x:Name="radSubTabPassword"
                                     Content="Đổi mật khẩu"
                                     Style="{StaticResource ProfileSubTabButton}"
                                     Checked="SubTabPassword_Checked"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="#990F0812"
                        BorderBrush="#22F36895"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="40"
                        Margin="0,0,0,20">
                    <Grid>
                        <StackPanel x:Name="pnlProfileInfo"
                                    Visibility="Visible">
                            <TextBlock x:Name="lblAccountInfoTitle"
